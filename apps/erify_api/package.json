{
  "name": "erify_api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm db:generate && nest build",
    "start": "cross-env NODE_ENV=production nest start",
    "dev": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/src/main",
    "db:migrate:create": "npx prisma migrate dev --create-only",
    "db:migrate:status": "npx prisma migrate status",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:migrate:reset": "npx prisma migrate reset --force",
    "db:seed": "npx prisma db seed",
    "db:local:refresh": "pnpm run db:migrate:reset && pnpm run db:migrate:deploy && pnpm run db:seed",
    "db:extid:sync": "tsx scripts/sync-ext-ids.ts",
    "db:local:refresh:with-ext-sync": "pnpm run db:local:refresh && pnpm run db:extid:sync",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:format": "npx prisma format",
    "db:validate": "npx prisma validate",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "manual:schedule:generate": "ts-node -r tsconfig-paths/register manual-test/schedule-planning/scripts/generate-schedule-payload.ts",
    "manual:schedule:create": "ts-node -r tsconfig-paths/register manual-test/schedule-planning/scripts/1.create-schedules.ts",
    "manual:schedule:upload": "ts-node -r tsconfig-paths/register manual-test/schedule-planning/scripts/2.upload-schedule-plan-documents.ts",
    "manual:schedule:validate": "ts-node -r tsconfig-paths/register manual-test/schedule-planning/scripts/3.validate-schedules.ts",
    "manual:schedule:publish": "ts-node -r tsconfig-paths/register manual-test/schedule-planning/scripts/4.publish-schedules.ts",
    "manual:schedule:all": "ts-node -r tsconfig-paths/register manual-test/schedule-planning/scripts/workflows/run-all.ts",
    "manual:backdoor:create-users": "ts-node -r tsconfig-paths/register manual-test/backdoor/scripts/1.create-users.ts",
    "manual:backdoor:update-users": "ts-node -r tsconfig-paths/register manual-test/backdoor/scripts/2.update-users.ts",
    "manual:backdoor:create-memberships": "ts-node -r tsconfig-paths/register manual-test/backdoor/scripts/3.create-memberships.ts",
    "manual:backdoor:all": "ts-node -r tsconfig-paths/register manual-test/backdoor/scripts/workflows/run-all.ts",
    "manual:auth:login": "ts-node -r tsconfig-paths/register manual-test/auth/scripts/1.login.ts",
    "manual:auth:test-me": "ts-node -r tsconfig-paths/register manual-test/auth/scripts/2.test-me.ts",
    "manual:auth:all": "ts-node -r tsconfig-paths/register manual-test/auth/scripts/workflows/run-all.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@eridu/api-types": "workspace:*",
    "@eridu/auth-sdk": "workspace:*",
    "@nestjs-cls/transactional": "^3.2.0",
    "@nestjs-cls/transactional-adapter-prisma": "^1.3.4",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@scalar/nestjs-api-reference": "^1.0.29",
    "dotenv": "^16.6.1",
    "helmet": "^8.1.0",
    "jose": "^6.1.3",
    "nanoid": "^5.1.6",
    "nestjs-cls": "^6.2.0",
    "nestjs-pino": "^4.6.0",
    "nestjs-zod": "^5.1.1",
    "pg": "^8.19.0",
    "pino-http": "^10.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@eridu/eslint-config": "workspace:*",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.2",
    "babel-jest": "^30.2.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
