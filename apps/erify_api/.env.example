# =============================================================================
# Eridu Services API - Environment Configuration Template
# =============================================================================
# Copy this file to .env and update the values for your environment

# Authentication & Authorization (JWT/JWKS)
ERIDU_AUTH_URL=http://localhost:3001
# used for internal service (optional)
ERIDU_PRIVATE_AUTH_URL=http://localhost:3001

# Database Configuration
DATABASE_URL=postgresql://admin:secret@localhost:5432/erify_api

# Server-to-Server Authentication
# Google Sheets integration API key (optional)
GOOGLE_SHEETS_API_KEY=your-google-sheets-api-key

BACKDOOR_API_KEY=

# Server Configuration
NODE_ENV=development
PORT=3000
# Body parser payload size limit for JSON/urlencoded requests
# Keep small by default; increase (e.g. 2mb) when importing large task templates
BODY_PARSER_LIMIT=100kb

# CORS Configuration
CORS_ENABLED=true
CORS_ORIGIN=*

# Graceful Shutdown
SHUTDOWN_TIMEOUT=30000

# Cloudflare R2 (S3-compatible storage)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional public CDN/domain base URL for uploaded objects
R2_PUBLIC_BASE_URL=
