# ==========================================
# Eridu Docs - Local Environment Configuration
# ==========================================

# Recommended local docs workflow:
# - docs run on localhost
# - auth is bypassed
# - eridu_auth does not need to be running
AUTH_URL=http://localhost:5173
BYPASS_AUTH=true

# Optional advanced overrides
# AUTH_API_URL: eridu_auth backend for JWKS + token exchange.
#   If omitted and AUTH_URL is localhost:5173, docs auto-uses localhost:3001.
# AUTH_UI_URL: explicit login UI URL. Defaults to AUTH_URL.
# AUTH_ISSUER_URL: explicit JWT issuer URL. Defaults to AUTH_URL, then AUTH_API_URL.
# Most setups do not need these.
# AUTH_API_URL=http://localhost:3001
# AUTH_UI_URL=http://localhost:5173
# AUTH_ISSUER_URL=http://localhost:5173

# Force Secure flag on docs JWT cookie.
# Default behavior:
# - localhost/127.0.0.1 => false
# - non-local + production build => true
# COOKIE_SECURE=true
