# eridu_docs — Environment Configuration
#
# Local dev: set BYPASS_AUTH=true. No other variables needed.
# Production: set AUTH_API_URL and AUTH_UI_URL. BYPASS_AUTH must be unset or false.

# Skip auth for local docs work (eridu_auth does not need to be running)
BYPASS_AUTH=true

# eridu_auth backend — JWKS, /api/auth/token, /api/auth/sign-out
# AUTH_API_URL=https://auth-api.eridu.io

# eridu_auth frontend — /sign-in redirect
# AUTH_UI_URL=https://auth.eridu.io

# Override JWT cookie Secure flag (default: true in production, false in dev)
# COOKIE_SECURE=true
