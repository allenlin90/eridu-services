# ==========================================
# Eridu Docs - Local Environment Configuration
# ==========================================

# 1. Cookie Name
# The cookie where the JWT is synced by the frontend (for SSR auth).
AUTH_COOKIE_NAME=eridu_jwt_token

# 2. Login Redirect URL
# Where unauthorized users are sent. For local testing, this should be your local auth app or studios frontend.
LOGIN_URL="http://localhost:3000/login"

# --- Local Development Only ---
# Set to 'true' to completely bypass the SSR Auth middleware.
# This prevents Starlight prerendering warnings in the terminal and disables the auth gate locally.
BYPASS_AUTH="true"
