# eridu_docs — Environment Configuration
#
# Local dev: set BYPASS_AUTH=true. No other variables needed.
# Production: set AUTH_URL. Set AUTH_INTERNAL_URL as well when server-side
# traffic to eridu_auth should stay on the cluster network. BYPASS_AUTH must be
# unset or false.

# Skip auth for local docs work (eridu_auth does not need to be running)
BYPASS_AUTH=true

# Browser-facing eridu_auth URL — used for /sign-in redirects and JWT issuer validation
# AUTH_URL=https://auth.eridu.io

# Internal eridu_auth URL — used for JWKS, /api/auth/token, and sign-out
# Falls back to AUTH_URL when unset.
# AUTH_INTERNAL_URL=http://eridu-auth:3001

# Override JWT cookie Secure flag (default: true in production, false in dev)
# COOKIE_SECURE=true
