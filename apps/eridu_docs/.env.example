# ==========================================
# Eridu Docs - Local Environment Configuration
# ==========================================

# 1. Authentication Secret
# This must match the secret used by your local `eridu_auth` instance to sign JWTs
JWT_SECRET=super_secret_local_jwt_key_123

# 2. Cookie Name
# The strict cookie name that the middleware looks for.
AUTH_COOKIE_NAME=eridu_session_token

# 3. Login Redirect URL
# Where unauthorized users are sent. For local testing, this should be your local auth app or studios frontend.
LOGIN_URL=http://localhost:3000/login
