# eridu_docs — Environment Configuration
#
# Local dev: set BYPASS_AUTH=true. No other variables needed.
# Production: set AUTH_URL. Set AUTH_INTERNAL_URL as well when server-side
# traffic to eridu_auth should stay on the cluster network. BYPASS_AUTH must be
# unset or false.

# Skip auth for local docs work (eridu_auth does not need to be running)
BYPASS_AUTH=true

# Public URL of this app — used as the base for /auth/callback in the sign-in redirect.
# Required in production: Railway's ingress sends Host: localhost:PORT to the container,
# so context.url.origin produces the wrong callbackURL without this.
# SITE_URL=https://docs.eridu.io

# Browser-facing eridu_auth URL — used for /sign-in redirects and JWT issuer validation
# AUTH_URL=https://auth.eridu.io

# Internal eridu_auth URL — used for JWKS, /api/auth/token, and sign-out
# Falls back to AUTH_URL when unset.
# AUTH_INTERNAL_URL=http://eridu-auth:3001

# Override JWT cookie Secure flag (default: true in production, false in dev)
# COOKIE_SECURE=true

# Shared secret for server-to-server sign-out (eridu_docs → eridu_auth /api/service/sign-out).
# Must be at least 32 characters and match SERVICE_SECRET in eridu_auth.
# Generate with: openssl rand -hex 32
# When unset, logout still clears the local docs cookie but does not revoke the Better Auth session.
# AUTH_SERVICE_SECRET=your-service-secret-at-least-32-chars
