# ==========================================
# Eridu Docs - Local Environment Configuration
# ==========================================

# Auth API URL (eridu_auth backend for JWKS + token exchange)
AUTH_API_URL="http://localhost:3001"

# Auth UI URL (eridu_auth frontend login page)
AUTH_UI_URL="http://localhost:5173"

# Legacy fallback (optional): if set, used for both API and UI.
# AUTH_URL="http://localhost:3001"

# Cookie domain for production (e.g. .eridu.io for cross-subdomain)
# Omit for local development (defaults to current host)
# COOKIE_DOMAIN=".eridu.io"

# Set to 'true' to bypass auth middleware in local development
BYPASS_AUTH="true"
