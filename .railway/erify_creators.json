{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npx turbo run build --filter=erify_creators",
    "watchPatterns": [
      "/apps/erify_creators/src/**",
      "/packages/api-types/**",
      "/packages/auth-sdk/**",
      "/packages/ui/**"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter erify_creators start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
