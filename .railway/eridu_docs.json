{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npx turbo run build --filter=eridu_docs",
    "watchPatterns": [
      "/apps/eridu_docs/src/**",
      "/apps/eridu_docs/public/**",
      "/apps/eridu_docs/scripts/**",
      "/apps/eridu_docs/astro.config.mjs",
      "/apps/eridu_docs/package.json",
      "/packages/auth-sdk/**"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter eridu_docs start",
    "healthcheckPath": "/favicon.png",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
