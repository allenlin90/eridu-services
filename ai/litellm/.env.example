# Scoped virtual key, NOT the LiteLLM proxy's real LITELLM_MASTER_KEY (that stays a Railway
# service secret and is never used for scripting). This key should carry access to management
# routes only (models/keys/teams/users/customers/budgets/spend) — no inference/model-calling
# routes (/v1/chat/completions, /v1/model/info, etc). Widen scope only if a task needs it, and
# only with sign-off; see litellm-admin-api SKILL.md.
LITELLM_ADMIN_KEY=YOUR_LITELLM_SCOPED_ADMIN_KEY_HERE
LITELLM_HOST=https://litellm.yourdomain.com
