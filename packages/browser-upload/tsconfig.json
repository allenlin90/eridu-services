{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@eridu/typescript-config/react-library.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "WebWorker"],
    "baseUrl": ".",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "./dist",
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.spec.ts", "src/**/*.test.ts"]
}
